<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<StackPane minWidth="500.0" prefWidth="540.0" stylesheets="@../styles/login_form.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox maxWidth="450.0" minWidth="400.0" prefHeight="768.0" prefWidth="450.0" styleClass="login-container">
         <children>
            <Region prefHeight="80.0" prefWidth="450.0" />
            <VBox prefHeight="90.0" prefWidth="450.0">
               <children>
                  <Label styleClass="form-title" text="Welcome Back !" />
                  <Label prefHeight="23.0" prefWidth="466.0" styleClass="form-subtitle" text="Log in to start managing the insurrance contracts with ease." />
               </children>
            </VBox>
            <VBox prefHeight="100.0" prefWidth="450.0" styleClass="input-group">
               <children>
                  <Label styleClass="input-label" text="Email" />
                  <TextField fx:id="tfEmail" prefHeight="28.0" prefWidth="450.0">
                     <styleClass>
                        <String fx:value="text-field" />
                        <String fx:value="password-field" />
                     </styleClass>
                  </TextField>
               </children>
            </VBox>
            <VBox prefHeight="89.0" prefWidth="450.0" styleClass="input-group">
               <children>
                  <Label styleClass="input-label" text="Password" />
                  <TextField fx:id="tfPassword" prefHeight="25.0" prefWidth="450.0" styleClass="password-field" />
               </children>
            </VBox>
            <HBox prefHeight="49.0" prefWidth="450.0" styleClass="options-row">
               <children>
                  <CheckBox mnemonicParsing="false" prefHeight="20.0" prefWidth="122.0" styleClass="checkbox" text="Remenber me" />
                  <Region prefHeight="31.0" prefWidth="218.0" HBox.hgrow="ALWAYS" />
                  <Hyperlink prefHeight="20.0" prefWidth="125.0" text="Forgot password?" textAlignment="RIGHT" />
               </children>
            </HBox>
            <HBox prefHeight="92.0" prefWidth="450.0">
               <children>
                  <Button fx:id="btnLogin" mnemonicParsing="false" prefHeight="46.0" prefWidth="448.0" styleClass="btn-primary" text="Login" />
               </children>
            </HBox>
            <HBox prefHeight="43.0" prefWidth="450.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="472.0" text="━━━━━━━━━━━━━━Or continue with:━━━━━━━━━━━━━━━" />
               </children>
            </HBox>
            <VBox prefHeight="69.0" prefWidth="450.0">
               <children>
                  <Button mnemonicParsing="false" prefHeight="34.0" prefWidth="450.0" styleClass="btn-secondary" text="Continue with Google">
                     <graphic>
                        <ImageView fitHeight="26.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/logo_google.jpg" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Button>
               </children>
            </VBox>
            <HBox prefHeight="30.0" prefWidth="450.0">
               <children>
                  <Label text="Don't have an account ?" />
                  <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Hyperlink fx:id="hplSingup" text="Sign up Here" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
